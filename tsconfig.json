{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"],
  },
  "include": ["*/src/**/*.ts", "*/**/*.test.ts", "*/**/*.spec.ts", "vitest.config.ts"],
  "exclude": ["node_modules", "coverage", "project-assigner", "*/dist/**"],
}
